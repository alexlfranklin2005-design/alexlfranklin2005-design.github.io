@page "/"
@implements IAsyncDisposable
@inject IJSRuntime JS
@inject NavigationManager Nav

<div class="stage-container" data-panel-state="@panelState" @ref="stageRef">

    <section class="photo-stage @(panelState == "open" ? "photo-stage--collapsed" : "")">

        <!-- 1. The looping background video (Leading slash removed for GitHub pages) -->
        <!-- Space in the path is percent-encoded (%20) - unencoded spaces in a
             src attribute can silently fail to load on some mobile browsers,
             which was the original cause of the blank background on phone. -->
        <video class="photo-stage__video" autoplay muted loop playsinline poster="images/Home%20Cover/fallback.jpg" @ref="videoRef">
                <source src="images/Home%20Cover/Loop.mp4" type="video/mp4" />
        </video>

        <!-- 2. The dark green gradient overlay to ensure text readability -->
        <div class="photo-stage__overlay"></div>

        <h1 class="photo-stage__title">
            @(panelState == "open" ? "ABOUT ME" : "IVY FISHER EVENTING")
        </h1>

        @if (panelState != "open")
        {
            <button class="reveal-btn reveal-btn--down" @onclick="OpenPanel" aria-label="Show more">
                <svg width="50" height="50" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="18 15 12 9 6 15"></polyline>
                </svg>
            </button>
        }
    </section>

    <section class="about-panel @panelState" @ref="panelRef">
        <div class="about-panel__layout">
            <div class="about-panel__photo">
                <!-- Headshot image (Leading slash removed for GitHub pages) -->
                <img src="images/About Headshot/Headshot.jpg" alt="Headshot of Ivy Fisher" />
            </div>
            <div class="about-panel__copy">
                <h3>My Background</h3>
                <p> I am a 21 year old aspiring professional event rider from Norfolk who is passionate about producing and competing event horses.</p>

                <h3>How I Got Into Horses</h3>
                <p>My passion for horses started later than some, sparking at a riding school I regularly had lessons at which I then got my first pony 'Indie' from. I then joined the North Norfolk branch of the Pony Club and climbed the ranks of the area teams, where I fell in love with eventing .</p>

                <h3>Best Experiences in Eventing So Far</h3>
                <p>The 2024 Young Rider Europeans is a career highlight for me so far. Global Promise ('Cleo') and I were lucky enough to be selected after a good 8th place at Burgham final trial. We went to Strzegom and put in a solid performance, finishing 11th after a 29 DC with a few time faults cross country. This year 'Balief De Reve' and I have been named on the longlist for Europeans in Sweden, and hope to make the step up to 4* at the end of the year.</p>
            </div>
        </div>

        <footer class="about-panel__footer">
            <img src="images/Logo/logo_banner.png" alt="Ivy Fisher Eventing Logo" class="about-panel__footer-logo" />
        </footer>
    </section>
</div>

@code {
    private string panelState = "closed";
    private double scrollAccumulator = 0;

    private const double MaxAccumulator = 220;

    private ElementReference stageRef;
    private ElementReference panelRef;
    private ElementReference videoRef;

    private IJSObjectReference? _module;
    private IJSObjectReference? _handler;
    private IJSObjectReference? _videoModule;
    private DotNetObjectReference<Home>? _dotNetRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        _dotNetRef = DotNetObjectReference.Create(this);
        _module = await JS.InvokeAsync<IJSObjectReference>("import", "./js/Scrollhandler.js");
        _handler = await _module.InvokeAsync<IJSObjectReference>("init", _dotNetRef, stageRef, panelRef);

        // Only ever calls play() if the video isn't already playing, so it
        // never races against - or interferes with - native autoplay on desktop.
        try
        {
            _videoModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/Videohelpers.js");
            await _videoModule.InvokeVoidAsync("initVideo", videoRef);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Video init skipped: {ex.Message}");
        }
    }

    [JSInvokable]
    public void OnWheelDelta(double deltaY)
    {
        if (deltaY > 0 && panelState != "open")
        {
            scrollAccumulator = MaxAccumulator;
            SetState("open");
        }
        else if (deltaY < 0 && panelState == "open")
        {
            scrollAccumulator = 0;
            SetState("closed");
        }
    }

    private void OpenPanel()
    {
        scrollAccumulator = MaxAccumulator;
        SetState("open");
    }

    private async Task ClosePanel()
    {
        scrollAccumulator = 0;
        SetState("closed");

        if (_handler is not null)
        {
            try { await _handler.InvokeVoidAsync("resetScroll"); } catch { }
        }
    }

    private void SetState(string newState)
    {
        if (newState == panelState) return;
        panelState = newState;
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        if (_handler is not null)
        {
            try { await _handler.InvokeVoidAsync("dispose"); } catch { }
            await _handler.DisposeAsync();
        }
        if (_module is not null)
        {
            await _module.DisposeAsync();
        }
        if (_videoModule is not null)
        {
            await _videoModule.DisposeAsync();
        }
        _dotNetRef?.Dispose();
    }
}
