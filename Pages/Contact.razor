@page "/contact"

<PageTitle>Contact</PageTitle>

<!-- Hero Banner (Permanently shrunk for this page) -->
<div class="hero-banner banner-shrunk contact-header-bg">
    <h1 class="hero-text">GET IN TOUCH</h1>
</div>

<!-- Main Contact Content -->
<div class="contact-section fade-in">
    <div class="contact-grid">

        <!-- Map Column -->
        <div class="map-container">
            <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3771.346468555446!2d-1.3865279869850595!3d52.14620526371909!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x48772faee526632d%3A0x6524a4d991d84b68!2sDassett%20Eventing!5e1!3m2!1sen!2suk!4v1782679060159!5m2!1sen!2suk"
                    width="100%" height="450" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="strict-origin-when-cross-origin"></iframe>
        </div>

        <!-- Contact Info Column -->
        <div class="contact-info-container">

            <!-- Phone Line -->
            <div class="contact-row">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="black" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.79 19.79 0 0 1 1 4.18 2 2 0 0 1 3 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
                <span class="label">Phone Number:</span>
                <a href="tel:+447548367707" class="black-text">07548367707</a>
            </div>

            <!-- Email Line -->
            <div class="contact-row">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="black" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
                <span class="label">Email Address:</span>
                <a href="mailto:ivyfisher23@gmail.com" class="black-text">ivyfisher23@gmail.com</a>
            </div>

            <!-- Instagram Line -->
            <div class="contact-row">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="black" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
                <span class="label">Instagram:</span>
                <a href="https://www.instagram.com/ivyfisher_eventing" target="_blank" class="black-text">ivyfisher_eventing</a>
            </div>
        </div>
    </div>
</div>

<!-- Ivy Leaf Footer: outside .contact-section on purpose, so it is never
     constrained by the section's padding and needs no negative-margin hacks -->
<footer class="contact-footer">
    <img src="images/Logo/logo_banner.png" alt="Ivy Fisher Eventing Logo" class="contact-footer-logo" />
</footer>
